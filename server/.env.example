PORT=3000
GESTIONAR_API_KEY=

# Supabase (service role + anon para verificar JWT en rutas admin)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Resend (emails de pedidos)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
# Opcional: para testear, enviar TODO a este email
RESEND_TEST_TO_EMAIL=

# Nave (pagos)
# Entorno: testing o production
NAVE_ENV=testing
NAVE_CLIENT_ID=
NAVE_CLIENT_SECRET=
# Opcionales: solo si Nave te los provee
NAVE_AUDIENCE=
NAVE_CACHE=
# POS ID proporcionado por Nave/Galicia
NAVE_POS_ID=

# Correo Argentino
CORREO_PROVIDER_MODE=micorreo
CORREO_ENV=qa

CORREO_MICORREO_BASE_URL_QA=https://apitest.correoargentino.com.ar/micorreo/v1
CORREO_MICORREO_BASE_URL_PROD=https://api.correoargentino.com.ar/micorreo/v1

CORREO_MICORREO_USERNAME=ACA_VA_EL_USERNAME_API
CORREO_MICORREO_PASSWORD=ACA_VA_EL_PASSWORD_API

CORREO_MICORREO_EMAIL=MAIL_DE_LA_CUENTA_MICORREO
CORREO_MICORREO_ACCOUNT_PASSWORD=PASSWORD_DE_LA_CUENTA_MICORREO

CORREO_CUSTOMER_ID=
CORREO_PRODUCT_TYPE=CP
CORREO_ORIGIN_POSTAL_CODE=CODIGO_POSTAL_ORIGEN
CORREO_ORIGIN_PROVINCE_CODE=B
CORREO_ORIGIN_AGENCY_CODE=CODIGO_DE_LA_SUCURSAL_ORIGEN
CORREO_TIMEOUT_MS=15000

# Si Correo nos habilita PAQ.AR API v2 seran algo asi: 
CORREO_PROVIDER_MODE=paqar
CORREO_ENV=qa

CORREO_PAQAR_BASE_URL_QA=...
CORREO_PAQAR_BASE_URL_PROD=...
CORREO_PAQAR_AGREEMENT=...
CORREO_PAQAR_API_KEY=...
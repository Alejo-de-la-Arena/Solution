PORT=3000
GESTIONAR_API_KEY=

# Supabase (service role + anon para verificar JWT en rutas admin)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Resend (emails de pedidos)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
# Opcional: para testear, enviar TODO a este email
RESEND_TEST_TO_EMAIL=

# Nave (pagos)
# Entorno: testing o production
NAVE_ENV=testing
NAVE_CLIENT_ID=
NAVE_CLIENT_SECRET=
# Requerido por documentación Nave M2M (ej. https://naranja.com/ranty/merchants/api)
NAVE_AUDIENCE=
NAVE_CACHE=
# POS ID proporcionado por Nave/Galicia
NAVE_POS_ID=
# Opcional: duration_time al crear la intención (Nave: segundos). Default en código: 600 (10 min).
# Para no enviar el campo (default del servidor Nave): NAVE_PAYMENT_DURATION_SECS=omit
# NAVE_PAYMENT_DURATION_SECS=
